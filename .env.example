DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS: origens do front (Vite dev e produção), separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (deixe vazio para SQLite local)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
# Opcional: SSL, ex. require
DB_SSLMODE=

# Telegram (opcional — pedido grava mesmo se falhar o envio)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
